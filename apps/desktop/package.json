{
  "name": "creditos-desktop",
  "version": "0.3.0",
  "private": true,
  "description": "Electron desktop app for Creditos.",
  "main": "main.js",
  "scripts": {
    "test": "node --test ../../test/desktop/*.test.js",
    "start": "node run-electron.js",
    "dev": "node run-electron.js",
    "repair-electron": "node repair-electron.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^38.1.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.jtorrens.creditos",
    "productName": "Creditos",
    "icon": "icon.png",
    "files": [
      "main.js",
      "preload.js",
      "native/**/*",
      "repair-electron.js",
      "run-electron.js",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/ffmpeg"
    ],
    "extraResources": [
      {
        "from": "../renderer",
        "to": "renderer"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity"
    }
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "fontkit": "^2.0.4"
  }
}
